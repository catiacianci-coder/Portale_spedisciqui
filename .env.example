APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Cartella dati esterna (etichette LdV, fatture, …) fuori dal progetto
SPEDISCIQUI_DATA_PATH=C:\spedisciqui-data

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Wallet ricarica: minimo EUR (fallback se manca parametro DB)
# WALLET_RICARICA_MIN=150
# Solo sviluppo: accredita senza gateway (non usare in produzione)
# WALLET_RICARICA_DEV=false

# Back-office: assegnare ruoli in role_user (es. super_user, assistenza, contabile)

# Integrazioni API (Stripe, Sendcloud, Spedisci.online, Liccardi TMS, Turnstile):
# NON usare .env — configurare in back-office → Parametri globali (tabella parametri_globalis).
# Alla prima migration i valori eventualmente presenti in .env vengono importati una tantum.

# Rimborsi etichette (giorni lavorativi lun–ven per motivo con etichetta)
# RIMBORSO_GIORNI_UTEIS=15
# RIMBORSO_DIAS_ELEGIBILIDADE=30
